TC_ENVIRONMENT=development
TC_HOST=127.0.0.1
TC_PORT=8000
TC_LOG_LEVEL=info
FRONTEND_ORIGIN=http://127.0.0.1:5173
TC_DATABASE_URL=postgresql+psycopg://triathlon:triathlon@localhost:5432/triathlon_coach

# Replace placeholders locally. Never commit real Strava credentials.
STRAVA_CLIENT_ID=replace_with_strava_client_id
STRAVA_CLIENT_SECRET=replace_with_strava_client_secret
STRAVA_REDIRECT_URI=http://127.0.0.1:8000/integrations/strava/callback
STRAVA_AUTHORIZATION_URL=https://www.strava.com/oauth/authorize
STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
STRAVA_REVOCATION_URL=https://www.strava.com/oauth/revoke
STRAVA_API_BASE_URL=https://www.strava.com/api/v3
STRAVA_SCOPES=read,activity:read_all
OAUTH_STATE_TTL_SECONDS=600
OAUTH_STATE_SQLITE_PATH=.oauth-state/oauth_state.sqlite3
OAUTH_STATE_DIAGNOSTICS=false
STRAVA_IMPORT_PAGE_SIZE=100
STRAVA_IMPORT_RETRY_SECONDS=60
STRAVA_IMPORT_OVERLAP_SECONDS=86400
TC_ACTIVITY_STREAM_RETENTION_ENABLED=true
TC_ACTIVITY_LOCATION_STREAM_RETENTION_ENABLED=false
TC_ACTIVITY_STREAM_MAX_SAMPLES=1000
TC_ACTIVITY_STREAM_RETENTION_DAYS=0
